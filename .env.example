# (Optional) Override Ollama URL if not running on localhost
# OLLAMA_BASE_URL=http://localhost:11434

# (Optional) Default model — can also be selected in the UI
# OLLAMA_MODEL=llama3.1:8b

# (Optional) Server port
# PORT=8000

# (Optional) Max log file size allowed (in MB)
# MAX_FILE_SIZE_MB=10

# (Optional) Knowledge graph storage directory
# KNOWLEDGE_GRAPH_DIR=./data/knowledge_graph
